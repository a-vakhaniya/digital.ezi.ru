---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  subtitle: string;
  description: string;
  href: string;
  image?: ImageMetadata;
  accent?: "mint" | "terracotta" | "lavender" | "sand";
}

const { title, subtitle, description, href, image, accent = "mint" } = Astro.props;

const accentShadow = {
  mint: "hover:shadow-glow-mint",
  terracotta: "hover:shadow-glow-terracotta",
  lavender: "hover:shadow-glow-lavender",
  sand: "hover:shadow-glow-sand",
};
---

<a
  href={href}
  class={`block overflow-hidden rounded-3xl bg-white/60 shadow-soft transition-shadow duration-200 ${accentShadow[accent]}`}
>
  <div class="h-64 w-full bg-mint/20">
    {image && <Image src={image} alt={title} class="h-64 w-full object-cover" quality={90} />}
  </div>
  <div class="p-6">
    <h3 class="text-xl font-bold">{title}</h3>
    <p class="mt-1 text-sm font-medium text-text/50">{subtitle}</p>
    <p class="mt-2 text-sm text-text/70">{description}</p>
  </div>
</a>
