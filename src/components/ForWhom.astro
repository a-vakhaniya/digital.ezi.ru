<section id="for-who" class="mx-auto max-w-6xl scroll-mt-20 px-4 py-16 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-bold">Для кого и как</h2>
  <div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-2">
    <div>
      <h3 class="text-xl font-bold">Для кого</h3>
      <ul class="mt-4 space-y-4 text-text/70">
        <li>
