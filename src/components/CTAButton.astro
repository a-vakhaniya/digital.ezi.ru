---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  class?: string;
}

const { href, variant = "primary", class: className = "" } = Astro.props;

const base =
  "inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition-shadow duration-200";

const variants = {
  primary: "bg-terracotta text-bg shadow-soft hover:shadow-glow-terracotta",
  secondary: "bg-transparent border border-text/20 text-text hover:shadow-soft",
};

const classes = `${base} ${variants[variant]} ${className}`;
const Tag = href ? "a" : "button";
---

<Tag class={classes} href={href} {...!href && { type: "submit" }}>
  <slot />
</Tag>
