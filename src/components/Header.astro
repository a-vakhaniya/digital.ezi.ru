---
const isHome = Astro.url.pathname === "/";

const navItems = [
  { label: "Обо мне", id: "about" },
  { label: "Кейсы", id: "portfolio" },
  { label: "Для кого", id: "for-who" },
  { label: "Контакты", id: "contact" },
];

const anchor = (id: string) => (isHome ? `#${id}` : `/#${id}`);
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-bg/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="inline-flex items-baseline text-xl font-bold tracking-wide text-text">
      digital
      <svg
        width="8"
        height="11"
        viewBox="0 0 12 16"
        style="position: relative; top: 1px; margin: 0 1px; flex-shrink: 0;"
      >
        <defs>
          <radialGradient id="logoDropShade" cx="35%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#D4967B"></stop>
            <stop offset="100%" stop-color="#A85F3D"></stop>
          </radialGradient>
        </defs>
        <path
          d="M6 0 C6 0 11 7.5 11 10.5 C11 13.5 8.8 16 6 16 C3.2 16 1 13.5 1 10.5 C1 7.5 6 0 6 0 Z"
          fill="url(#logoDropShade)"
        ></path>
      </svg>
      ezi
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {
        navItems.map((item) => (
          <a
            href={anchor(item.id)}
            class="text-sm font-medium text-text/80 transition-colors hover:text-text"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <button
      type="button"
      id="nav-toggle"
      aria-label="Открыть меню"
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="flex h-10 w-10 items-center justify-center text-text md:hidden"
    >
      <svg
        id="icon-burger"
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        class="hidden h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav id="mobile-nav" class="hidden flex-col gap-1 border-t border-black/5 bg-bg px-4 pb-4 md:hidden">
    {
      navItems.map((item) => (
        <a
          href={anchor(item.id)}
          class="rounded-lg px-2 py-3 text-base font-medium text-text/80 hover:bg-black/5 hover:text-text"
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const iconBurger = document.getElementById("icon-burger");
  const iconClose = document.getElementById("icon-close");

  function setOpen(open: boolean) {
    mobileNav?.classList.toggle("hidden", !open);
    mobileNav?.classList.toggle("flex", open);
    iconBurger?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    toggle?.setAttribute("aria-expanded", String(open));
  }

  toggle?.addEventListener("click", () => {
    setOpen(mobileNav?.classList.contains("hidden") ?? false);
  });

  mobileNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });
</script>
