---
const technologies = ["Astro", "Tailwind CSS", "HTML/CSS/JS", "Python", "n8n"];
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-bold">Стек технологий</h2>
  <div class="mt-8 flex flex-wrap gap-4">
    {
      technologies.map((tech) => (
        <span class="rounded-2xl bg-white/60 px-6 py-4 text-sm font-semibold shadow-soft">
          {tech}
        </span>
      ))
    }
  </div>
</section>
